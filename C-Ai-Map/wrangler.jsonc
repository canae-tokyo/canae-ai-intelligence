{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "canae-ai-intelligence",
  "main": "src/worker.mjs",
  "compatibility_date": "2026-07-20",
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "run_worker_first": [
      "/internal",
      "/internal/*"
    ],
    "not_found_handling": "404-page"
  }
}
